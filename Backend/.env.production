# Production Environment Variables Template
# Copy these to your deployment platform's environment variables

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-railway-app.railway.app,your-domain.com

# Database (Railway/Render will provide this automatically)
# DATABASE_URL=postgresql://user:password@host:port/database

# API Keys
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# CORS Settings (Update with your Vercel domain)
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com
CORS_ALLOW_ALL=0

# Security
CSRF_TRUSTED_ORIGINS=https://your-railway-app.railway.app,https://your-vercel-app.vercel.app

# Email (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# File Upload Limits
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=31457280

# Logging
LOG_LEVEL=INFO